{
  "name": "w4u",
  "version": "0.1.0",
  "private": true,
  "description": "W4U (Work For You) - Peer-to-peer platform for South Africa's informal economy",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/mobile"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @w4u/api",
    "dev:mobile": "npm run start -w @w4u/mobile",
    "build:api": "npm run build -w @w4u/api",
    "build:shared": "npm run build -w @w4u/shared",
    "db:migrate": "npm run migrate -w @w4u/api",
    "db:migrate:rollback": "npm run migrate:rollback -w @w4u/api",
    "db:seed": "npm run seed -w @w4u/api",
    "lint": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
